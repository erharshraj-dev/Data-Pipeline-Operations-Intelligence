# ==========================================================
# Adaptive Intelligence Fabric (AIF)
# Multi-LLM Selection Agent — Environment Variables
#
# Copy this file to .env and fill in real values. Never commit
# the real .env file. Every value below is read only from the
# environment (see agents/multi_llm_selection/llm_config.py) —
# nothing here is hardcoded anywhere in the codebase.
# ==========================================================

# ----------------------------------------------------------
# Gemini
# ----------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TIMEOUT_SECONDS=20
GEMINI_MAX_RETRIES=2

# ----------------------------------------------------------
# Grok (xAI)
# ----------------------------------------------------------
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-4-latest
GROK_TEMPERATURE=0.2
GROK_MAX_OUTPUT_TOKENS=512
GROK_TIMEOUT_SECONDS=20
GROK_MAX_RETRIES=2

# ----------------------------------------------------------
# Ollama (local — no API key required)
# ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_RETRIES=1

# ----------------------------------------------------------
# Selection Order
#
# Comma-separated, tried left to right. If every provider in
# this list fails or is unset, the Recommendation Agent's
# deterministic rule-based recommendation is used instead.
# ----------------------------------------------------------
LLM_SELECTION_ORDER=gemini,grok,ollama
